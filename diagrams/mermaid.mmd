classDiagram
    class Pet {
        +String id
        +String name
        +String species
        +int age
        +List~Task~ tasks
        +add_task(Task)
    }

    class Task {
        +String id
        +String name
        +String category
        +int frequency_per_week
        +int duration_minutes
        +String priority
    }

    class Constraint {
        +String type
        +datetime start_time
        +datetime end_time
        +List~String~ available_days
        +is_satisfied(datetime)
    }

    class DailyPlan {
        +datetime date
        +List~Task~ tasks
        +String rationale
        +generate(Pet)
    }

    Pet "1" *-- "*" Task : has
    Task "1" *-- "*" Constraint : has
    DailyPlan "1" *-- "*" Task : schedules
